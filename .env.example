# Matrix connection
MATRIX_HOMESERVER_URL=http://localhost:6167
MATRIX_ACCESS_TOKEN=

# Imported bot credentials (alternative to MATRIX_ACCESS_TOKEN)
# Populate these by running: node setup/import-bot-blob.mjs 'db1:...'
MATRIX_BOT_USER_ID=
MATRIX_BOT_PASSWORD=
MATRIX_BOT_RECOVERY_KEY=
BRIDGE_ROOM_ID=

# Security — comma-separated Matrix user IDs (e.g. @alice:matron.chat)
# Leave empty to allow any user
ALLOWED_USER_IDS=

# Coding agent defaults
DEFAULT_WORKDIR=~/
# claude or codex. Can be overridden per command with --claude / --codex.
MATRON_DEFAULT_AGENT=claude
SESSION_TIMEOUT=3600000
ENCRYPT_SESSION_ROOMS=1
BRIDGE_CLAUDE_MD_PATH=
# Codex programmatic mode (`codex exec --json`)
BRIDGE_CODEX_MD_PATH=
# read-only, workspace-write, or danger-full-access
CODEX_SANDBOX_MODE=workspace-write

# Debug mode (set to 1 for verbose logging)
DEBUG=0

# File viewer (optional)
HMAC_SECRET=
VIEWER_BASE_URL=
LINK_EXPIRY_MS=900000

# API ports
MATRIX_BRIDGE_API_PORT=9802
MATRIX_VIEWER_PORT=9803

# Voice note transcription (optional — requires whisper.cpp)
WHISPER_MODEL_PATH=
WHISPER_LANGUAGE=en

# Journal dual-post (optional) — mirrors session traffic into the matron-journal
# server alongside Matrix during the Matrix -> journal migration. Leave
# JOURNAL_WS_URL or the token unset to disable; a journal outage never affects
# Matrix behavior either way. Requires a bridge restart to take effect.
# Media mirroring (uploaded files/images -> journal file/image events) and
# read-marker advance need no config of their own — the media HTTP endpoint
# is derived from JOURNAL_WS_URL (ws:// -> http://, wss:// -> https://, strip
# the trailing /ws) and reuses the same agent token.
# Activity indicators (typing/"running <command>…" for viewing Matron clients)
# also ride this same connection — no new vars either. Ephemeral and
# best-effort: never queued/buffered/replayed, so a bridge restart or a brief
# journal outage just means a missed indicator, not a stale one later.
# In-progress assistant-text streaming (a live overlay for viewing Matron
# clients while Claude is still typing a reply) rides this same connection too —
# same ephemeral, best-effort, viewing-scoped contract as activity; the durable
# final message is published exactly as before and carries the ref that retires
# the overlay. Only the coalescing rate below is tunable.
# Same "requires a bridge restart to take effect" as everything else here.
JOURNAL_WS_URL=ws://127.0.0.1:9810/ws
# Optional: bridge-side stream coalescing floor in ms (at most one in-progress
# frame per conversation+message per window). Defaults to 200 (~5/s), matching
# the journal server's own fan-out coalescing — sending faster is wasted work.
# Non-positive/unparseable values fall back to the default.
JOURNAL_STREAM_INTERVAL_MS=200
# Path to a file containing the agent token (read once at boot, trimmed).
# Takes precedence over JOURNAL_TOKEN if both are set.
JOURNAL_TOKEN_FILE=
# Raw agent token (alternative to JOURNAL_TOKEN_FILE).
JOURNAL_TOKEN=
# Return path (Matron -> bridge input): where the inbound cursor (highest
# journal seq consumed) is persisted, debounced, so a bridge restart resumes
# input from where it left off instead of reconnecting live-only forever. No
# file yet -> first connect is live-only (never replays history as input).
# Default: journal-cursor.json in the repo root.
JOURNAL_CURSOR_FILE=
# Stable journal conversation id Matron sends session-management commands
# into (new/list/help — see README). Default: bridge-<hostname>.
JOURNAL_CONTROL_CONVO_ID=
