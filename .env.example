# Matrix connection
MATRIX_HOMESERVER_URL=http://localhost:6167
MATRIX_ACCESS_TOKEN=

# Imported bot credentials (alternative to MATRIX_ACCESS_TOKEN)
# Populate these by running: node setup/import-bot-blob.mjs 'db1:...'
MATRIX_BOT_USER_ID=
MATRIX_BOT_PASSWORD=
MATRIX_BOT_RECOVERY_KEY=
BRIDGE_ROOM_ID=

# Security — comma-separated Matrix user IDs (e.g. @alice:matron.chat)
# Leave empty to allow any user
ALLOWED_USER_IDS=

# Claude Code defaults
DEFAULT_WORKDIR=~/
SESSION_TIMEOUT=3600000
ENCRYPT_SESSION_ROOMS=1
BRIDGE_CLAUDE_MD_PATH=

# MCP / plugin memory (small-VPS friendly; see docs/superpowers/specs)
# Comma-separated extras applied to EVERY session on this machine (names must
# match mcpExtras keys in mcp-config.json or mcp-config.local.json), e.g. circleci
MCP_DEFAULT_EXTRAS=
# Dir that plugin MCP servers (context7, serena, …) load from. Unset = a
# bridge-owned EMPTY dir (no plugin MCPs, lean). Point at ~/.claude/plugins to
# re-enable all plugins, or a curated dir for a subset.
BRIDGE_PLUGIN_CACHE_DIR=

# Debug mode (set to 1 for verbose logging)
DEBUG=0

# File viewer (optional)
HMAC_SECRET=
VIEWER_BASE_URL=
LINK_EXPIRY_MS=900000

# API ports
MATRIX_BRIDGE_API_PORT=9802
MATRIX_VIEWER_PORT=9803

# Voice note transcription (optional — requires whisper.cpp)
WHISPER_MODEL_PATH=
WHISPER_LANGUAGE=en
