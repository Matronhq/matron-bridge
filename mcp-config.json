{
  "mcpServers": {
    "ask-user": {
      "command": "node",
      "args": ["./ask-user.js"],
      "env": {
        "BRIDGE_API_URL": "http://127.0.0.1:9802"
      }
    }
  },
  "mcpExtras": {
    "browser": {
      "chrome-devtools": {
        "command": "./hooks/xvfb-wrap.sh",
        "args": ["npx", "-y", "chrome-devtools-mcp", "--no-usage-statistics", "--acceptInsecureCerts", "--chromeArg=--no-sandbox", "--chromeArg=--disable-setuid-sandbox", "--viewport=1920x1080"]
      }
    }
  }
}
