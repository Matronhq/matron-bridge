{
  "mcpServers": {
    "ask-user": {
      "command": "node",
      "args": [
        "/home/danbarker/claude-matrix-bridge/ask-user.js"
      ],
      "env": {
        "BRIDGE_API_URL": "http://127.0.0.1:9802"
      }
    },
    "chrome-devtools": {
      "command": "xvfb-run",
      "args": [
        "--auto-servernum",
        "--server-args=-screen 0 1920x1080x24",
        "npx",
        "-y",
        "chrome-devtools-mcp",
        "--no-usage-statistics",
        "--acceptInsecureCerts",
        "--chromeArg=--no-sandbox",
        "--chromeArg=--disable-setuid-sandbox",
        "--viewport=1920x1080"
      ]
    }
  }
}